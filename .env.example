TG_TOKEN=your_telegram_bot_token
MAX_TOKEN=your_max_bot_token

# Max file size for forwarding (in MB). 0 or not set = unlimited.
# TG→MAX: Telegram getFile API is limited to 20 MB (standard API) or up to 4 GB (local API + Premium).
# MAX→TG: Telegram Bot API sendDocument is limited to 50 MB (standard) or up to 4 GB (local API + Premium).
# TG_MAX_FILE_SIZE_MB=20
# MAX_MAX_FILE_SIZE_MB=20

# SQLite (по умолчанию, без docker-compose)
# DB_PATH=bridge.db

# PostgreSQL (docker-compose)
# POSTGRES_USER=bridge
# POSTGRES_PASSWORD=bridge
# POSTGRES_DB=bridge

# Webhook (опционально)
# WEBHOOK_URL=https://bridge.example.com
# WEBHOOK_PORT=8443

# Локальный Telegram Bot API сервер (снимает лимиты на размер файлов, до 4 ГБ с Premium)
# Получите API_ID и API_HASH на https://my.telegram.org
# При использовании docker-compose значения ниже проставляются автоматически.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# URL локального Bot API сервера. Если не задан — используется стандартный (лимит 50 МБ).
# В docker-compose выставляется автоматически: TG_API_URL=http://telegram-bot-api:8081
# TG_API_URL=http://telegram-bot-api:8081

# Уровень логирования: debug, info (по умолчанию), warn, error
# LOG_LEVEL=info

# Белый список Telegram user ID (comma-separated). Если не задан — доступ открыт для всех.
# ALLOWED_USERS=123456789,987654321

# TG chat ID куда слать системные уведомления и ошибки. По умолчанию берется первый ID из ALLOWED_USERS.
# ADMIN_CHAT_ID=  # Your Telegram user ID for error notifications
